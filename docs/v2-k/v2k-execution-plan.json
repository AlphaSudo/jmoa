{
  "metadataVersion": "v2k-execution-plan",
  "primaryTarget": "doctor-corrected-d2",
  "fallbackTarget": "spring-petclinic-visits-service",
  "gates": [
    {
      "id": "K1",
      "lane": "doctor",
      "name": "Doctor runtime inventory",
      "outputs": [
        "scripts/doctor-runtime-inventory.ps1",
        "v2k-doctor-runtime-inventory.md",
        "v2k-doctor-runtime-inventory.json",
        "v2k-doctor-runtime-inventory-update.md",
        "v2k-doctor-runtime-inventory-update.json"
      ]
    },
    {
      "id": "K2",
      "lane": "doctor",
      "name": "Doctor CDS policy",
      "preferred": "D2 + corrected D2 CDS vs D2R + freshly trained D2R CDS",
      "allowedDiagnostic": "D2 no-CDS vs D2R no-CDS",
      "forbidden": [
        "reuse old D2 CDS archive with raw-reduced D2R artifact",
        "compare historical CDS baseline to no-CDS reduced candidate"
      ]
    },
    {
      "id": "K3",
      "lane": "doctor",
      "name": "Doctor image rebuild and runtime materialization proof"
    },
    {
      "id": "K4",
      "lane": "doctor",
      "name": "Doctor semantic smoke",
      "condition": "only after K1-K3 are clean"
    },
    {
      "id": "K5",
      "lane": "doctor",
      "name": "Doctor runtime screen",
      "condition": "only after semantic smoke passes"
    },
    {
      "id": "K6",
      "lane": "doctor",
      "name": "Doctor V2-C/V2-D confirmation",
      "condition": "only if Doctor runtime screen passes"
    },
    {
      "id": "VISITS-K1",
      "lane": "public-fallback",
      "name": "Artifact build",
      "outputs": [
        "baseline or full-P2 artifact",
        "raw-reduced artifact"
      ]
    },
    {
      "id": "VISITS-K2",
      "lane": "public-fallback",
      "name": "Artifact smoke",
      "gate": [
        "bytes removed > 0",
        "0 failed raw byte-preservation audits",
        "manifest v2 present",
        "jar count stable"
      ],
      "outputs": [
        "v2k-visits-artifact-smoke.md",
        "v2k-visits-artifact-smoke.json"
      ]
    },
    {
      "id": "VISITS-K3",
      "lane": "public-fallback",
      "name": "Semantic smoke",
      "gate": [
        "health UP",
        "representative workload",
        "0 workload errors",
        "no VerifyError",
        "no ClassFormatError",
        "no linkage errors"
      ]
    },
    {
      "id": "VISITS-K4",
      "lane": "public-fallback",
      "name": "Runtime screen",
      "gate": [
        "artifact smaller",
        "workload errors = 0",
        "PSS not worse by > 1 MB",
        "Private_Dirty not worse by > 1 MB",
        "memory.current not worse by > 1 MB"
      ]
    },
    {
      "id": "VISITS-K5",
      "lane": "public-fallback",
      "name": "V2-C/V2-D confirmation",
      "condition": "only if runtime screen passes"
    }
  ],
  "claimRules": {
    "confirmed": "second public runtime confirmation for raw reducer",
    "screenFailed": "raw reducer remains PetClinic customers-service confirmed only",
    "blocked": "no runtime claim"
  }
}
